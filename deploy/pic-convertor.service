[Unit]
Description=Pic Convertor FastAPI Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/pic_convertor
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/pic_convertor/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
